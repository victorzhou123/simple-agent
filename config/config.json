{
  "model": {
    "claude": {
      "api_key": "sk-NdSj893IGC0HHk8WFMspIBvymVIUzLd6woEhOpygFHFVrQss",
      "base_url": "https://terminal.pub",
      "model": "claude-opus-4-6"
    }
  },
  "ui": {
    "tea": {
      "tea": {
        "model_name": "claude-opus-4-6",
        "endpoint": "https://terminal.pub"
      },
      "formatter": {
        "bash": "🔧",
        "read_file": "📄",
        "write_file": "✏️",
        "edit_file": "📝",
        "todo": "📋",
        "subagent": "🤖"
      }
    }
  },
  "tools": {
    "tools": [
      {
        "name": "bash",
        "description": "Run a shell command.",
        "input_schema": {
          "properties": {
            "command": {"type": "string"}
          },
          "required": ["command"]
        }
      },
      {
        "name": "read_file",
        "description": "Read file contents.",
        "input_schema": {
          "properties": {
            "path":  {"type": "string"},
            "limit": {"type": "integer"}
          },
          "required": ["path"]
        }
      },
      {
        "name": "write_file",
        "description": "Write content to file.",
        "input_schema": {
          "properties": {
            "path":    {"type": "string"},
            "content": {"type": "string"}
          },
          "required": ["path", "content"]
        }
      },
      {
        "name": "edit_file",
        "description": "Replace exact text in file.",
        "input_schema": {
          "properties": {
            "path":     {"type": "string"},
            "old_text": {"type": "string"},
            "new_text": {"type": "string"}
          },
          "required": ["path", "old_text", "new_text"]
        }
      },
      {
        "name": "todo",
        "description": "Update task list. Track progress on multi-step tasks.",
        "input_schema": {
          "properties": {
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id":     {"type": "string"},
                  "text":   {"type": "string"},
                  "status": {"type": "string", "enum": ["pending", "in_progress", "completed"]}
                },
                "required": ["id", "text", "status"]
              }
            }
          },
          "required": ["items"]
        }
      },
      {
        "name": "subagent",
        "description": "Delegate a task to a subagent with fresh context. The subagent has access to all tools except subagent itself. Use this for independent subtasks that don't need the full conversation history.",
        "input_schema": {
          "properties": {
            "prompt": {
              "type": "string",
              "description": "The task or question for the subagent to handle"
            }
          },
          "required": ["prompt"]
        }
      }
    ],
    "subagent": {
      "prompt": "You are a helpful AI assistant that can use tools to accomplish tasks. You have access to a limited set of tools. Use them to answer questions and complete tasks. Always provide a clear summary of your findings at the end.",
      "max_rounds": 30
    }
  }
}
